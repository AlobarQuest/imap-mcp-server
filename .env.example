# IMAP MCP Server Configuration
# Copy to .env and fill in your values

# Transport mode (streamable-http for production)
MCP_TRANSPORT=streamable-http
PORT=8000

# Account 1
IMAP_ACCOUNT_1_NAME=adjustright
IMAP_ACCOUNT_1_EMAIL=devon@adjustrightga.com
IMAP_ACCOUNT_1_IMAP_HOST=mail.privateemail.com
IMAP_ACCOUNT_1_IMAP_PORT=993
IMAP_ACCOUNT_1_SMTP_HOST=mail.privateemail.com
IMAP_ACCOUNT_1_SMTP_PORT=587
# IMAP_ACCOUNT_1_SMTP_SECURITY=starttls  # starttls (default, port 587) or ssl (port 465)
IMAP_ACCOUNT_1_USERNAME=devon@adjustrightga.com
IMAP_ACCOUNT_1_PASSWORD=your-password-here
# IMAP_ACCOUNT_1_TRASH_FOLDER=Trash  # override if provider uses different name

# Account 2
IMAP_ACCOUNT_2_NAME=watkinshomesales
IMAP_ACCOUNT_2_EMAIL=devon@watkinshomesales.com
IMAP_ACCOUNT_2_IMAP_HOST=mail.privateemail.com
IMAP_ACCOUNT_2_IMAP_PORT=993
IMAP_ACCOUNT_2_SMTP_HOST=mail.privateemail.com
IMAP_ACCOUNT_2_SMTP_PORT=587
# IMAP_ACCOUNT_2_SMTP_SECURITY=starttls
IMAP_ACCOUNT_2_USERNAME=devon@watkinshomesales.com
IMAP_ACCOUNT_2_PASSWORD=your-password-here
# IMAP_ACCOUNT_2_TRASH_FOLDER=Trash

# Add more accounts by incrementing the number:
# IMAP_ACCOUNT_3_NAME=...
# IMAP_ACCOUNT_3_EMAIL=...
# etc.
